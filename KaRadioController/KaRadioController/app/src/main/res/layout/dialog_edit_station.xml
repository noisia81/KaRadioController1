<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#0A0A0F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/edit_station_title"
            android:background="#444433"
            android:textColor="#FFF"
            android:padding="8dp"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="monospace"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/slot_number_label"
                android:textColor="#FFF"
                android:fontFamily="monospace"
                android:layout_gravity="center_vertical"
                android:paddingEnd="12dp"
                android:paddingStart="0dp"
                android:labelFor="@+id/etEditSlot"/>
            <EditText
                android:id="@+id/etEditSlot"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:background="#FFF"
                android:textColor="#000"
                android:padding="6dp"
                android:enabled="false"
                android:fontFamily="monospace"
                android:textSize="14sp"
                android:inputType="number"
                android:importantForAutofill="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/name_label"
                android:textColor="#FFF"
                android:fontFamily="monospace"
                android:layout_gravity="center_vertical"
                android:paddingTop="12dp"
                android:labelFor="@+id/etEditName"/>
            <EditText
                android:id="@+id/etEditName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:background="#FFF"
                android:textColor="#000"
                android:padding="6dp"
                android:layout_marginTop="12dp"
                android:fontFamily="monospace"
                android:textSize="14sp"
                android:inputType="text"
                android:importantForAutofill="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/full_url_label"
                android:textColor="#FFF"
                android:fontFamily="monospace"
                android:layout_gravity="center_vertical"
                android:paddingTop="12dp"
                android:labelFor="@+id/etEditFullUrl"/>
            <EditText
                android:id="@+id/etEditFullUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:background="#FFF"
                android:textColor="#000"
                android:padding="6dp"
                android:layout_marginTop="12dp"
                android:hint="@string/url_hint"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:inputType="textUri"
                android:importantForAutofill="no" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/or_separator"
                android:textColor="#555"
                android:fontFamily="monospace"
                android:layout_columnSpan="2"
                android:gravity="center"
                android:padding="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/url_label"
                android:textColor="#FFF"
                android:fontFamily="monospace"
                android:layout_gravity="center_vertical"
                android:labelFor="@+id/etEditUrlOnly"/>
            <EditText
                android:id="@+id/etEditUrlOnly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:background="#FFF"
                android:textColor="#000"
                android:padding="6dp"
                android:fontFamily="monospace"
                android:textSize="14sp"
                android:inputType="textUri"
                android:importantForAutofill="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/port_label"
                android:textColor="#FFF"
                android:fontFamily="monospace"
                android:layout_gravity="center_vertical"
                android:paddingTop="12dp"
                android:labelFor="@+id/etEditPort"/>
            <EditText
                android:id="@+id/etEditPort"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:background="#FFF"
                android:textColor="#000"
                android:padding="6dp"
                android:layout_marginTop="12dp"
                android:fontFamily="monospace"
                android:inputType="number"
                android:textSize="14sp"
                android:importantForAutofill="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/path_label"
                android:textColor="#FFF"
                android:fontFamily="monospace"
                android:layout_gravity="center_vertical"
                android:paddingTop="12dp"
                android:labelFor="@+id/etEditPath"/>
            <EditText
                android:id="@+id/etEditPath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:background="#FFF"
                android:textColor="#000"
                android:padding="6dp"
                android:layout_marginTop="12dp"
                android:fontFamily="monospace"
                android:textSize="14sp"
                android:inputType="text"
                android:importantForAutofill="no" />
        </GridLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vol_offset_label"
                android:textColor="#FFF"
                android:fontFamily="monospace"
                android:paddingEnd="8dp"
                android:paddingStart="0dp"
                android:textSize="12sp"/>
            <SeekBar
                android:id="@+id/sbEditOvol"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="20"
                android:progress="10"/>
            <TextView
                android:id="@+id/tvEditOvolVal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFF"
                android:fontFamily="monospace"
                android:paddingStart="8dp"
                android:paddingEnd="0dp"/>
        </LinearLayout>

        <LinearLayout
            style="?android:attr/buttonBarStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="32dp"
            android:gravity="center">
            <Button
                style="?android:attr/buttonBarButtonStyle"
                android:id="@+id/btnEditSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:text="@string/btn_save"
                android:backgroundTint="#555544"
                android:textColor="#FFF"
                android:fontFamily="monospace"
                android:layout_marginEnd="8dp"
                android:textAllCaps="false"/>
            <Button
                style="?android:attr/buttonBarButtonStyle"
                android:id="@+id/btnEditErase"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:text="@string/btn_erase"
                android:backgroundTint="#555544"
                android:textColor="#FFF"
                android:fontFamily="monospace"
                android:layout_marginEnd="8dp"
                android:textAllCaps="false"/>
            <Button
                style="?android:attr/buttonBarButtonStyle"
                android:id="@+id/btnEditAbort"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:text="@string/btn_abort"
                android:backgroundTint="#555544"
                android:textColor="#FFF"
                android:fontFamily="monospace"
                android:textAllCaps="false"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
